<% content_for :title, "Orders — MOCK-FUND" %>
<div class="terminal-page-head">
  <h1 class="terminal-page-title">TRADE HISTORY</h1>
  <div class="terminal-page-meta">Portfolio #<%= @portfolio.id %></div>
</div>
<div class="terminal-window">
  <table class="terminal-table">
    <thead>
      <tr>
        <th>TIME</th>
        <th>TYPE</th>
        <th>SYM</th>
        <th class="num">QTY</th>
        <th class="num">PRICE</th>
      </tr>
    </thead>
    <tbody>
      <% @trades.order(executed_at: :desc, created_at: :desc).each do |t| %>
        <tr>
          <td><%= (t.executed_at || t.created_at).strftime("%Y-%m-%d %H:%M") %></td>
          <td class="<%= t.trade_type == "buy" ? "terminal-text-up" : "terminal-text-down" %>"><%= t.trade_type.upcase %></td>
          <td><%= t.symbol %></td>
          <td class="num"><%= t.quantity %></td>
          <td class="num"><%= number_to_currency(t.price, precision: 4) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="terminal-panel-actions">
    <%= link_to "NEW TRADE", new_portfolio_trade_path(@portfolio), class: "terminal-btn terminal-btn-primary" %>
  </div>
</div>
